{
  "isif": {
    "prefix": "isif",
    "body": [
      "<isif condition=\"${1:condition}\">",
      "\t$0",
      "</isif>"
    ],
    "description": "ISML <isif> conditional block"
  },
  "isif-else": {
    "prefix": "isifelse",
    "body": [
      "<isif condition=\"${1:condition}\">",
      "\t$2",
      "<iselse/>",
      "\t$0",
      "</isif>"
    ],
    "description": "ISML <isif>/<iselse> conditional block"
  },
  "isif-elseif-else": {
    "prefix": "isifelseif",
    "body": [
      "<isif condition=\"${1:firstCondition}\">",
      "\t$2",
      "<iselseif condition=\"${3:secondCondition}\"/>",
      "\t$4",
      "<iselse/>",
      "\t$0",
      "</isif>"
    ],
    "description": "ISML <isif>/<iselseif>/<iselse> conditional block"
  },
  "iselse": {
    "prefix": "iselse",
    "body": ["<iselse/>"],
    "description": "ISML <iselse/> branch"
  },
  "iselseif": {
    "prefix": "iselseif",
    "body": ["<iselseif condition=\"${1:condition}\"/>"],
    "description": "ISML <iselseif/> branch"
  },
  "isloop": {
    "prefix": "isloop",
    "body": [
      "<isloop items=\"${1:items}\" var=\"${2:item}\">",
      "\t$0",
      "</isloop>"
    ],
    "description": "ISML <isloop> iteration"
  },
  "isloop-status": {
    "prefix": "isloopstatus",
    "body": [
      "<isloop items=\"${1:items}\" var=\"${2:item}\" status=\"${3:loopstate}\">",
      "\t$0",
      "</isloop>"
    ],
    "description": "ISML <isloop> with loop status object"
  },
  "isinclude-template": {
    "prefix": "isinclude",
    "body": ["<isinclude template=\"${1:path/to/template}\"/>"],
    "description": "Include another ISML template"
  },
  "isinclude-url": {
    "prefix": "isincludeurl",
    "body": ["<isinclude url=\"${1:URLUtils.url('Controller-Action')}\"/>"],
    "description": "Include a remote URL"
  },
  "isset": {
    "prefix": "isset",
    "body": ["<isset name=\"${1:name}\" value=\"${2:value}\" scope=\"${3|page,request,session|}\"/>"],
    "description": "Set a variable in ISML"
  },
  "isscript": {
    "prefix": "isscript",
    "body": [
      "<isscript>",
      "\t$0",
      "</isscript>"
    ],
    "description": "ISML <isscript> server-side script block"
  },
  "isdecorate": {
    "prefix": "isdecorate",
    "body": [
      "<isdecorate template=\"${1:common/layout/page}\">",
      "\t$0",
      "</isdecorate>"
    ],
    "description": "Decorate template with a layout"
  },
  "iscontent": {
    "prefix": "iscontent",
    "body": ["<iscontent type=\"${1|text/html,text/xml,application/json,text/plain|}\" charset=\"${2:UTF-8}\" compact=\"${3|true,false|}\"/>"],
    "description": "Set the response content type"
  },
  "iscomment": {
    "prefix": "iscomment",
    "body": [
      "<iscomment>",
      "\t$0",
      "</iscomment>"
    ],
    "description": "ISML comment block (not rendered)"
  },
  "ismodule": {
    "prefix": "ismodule",
    "body": ["<ismodule template=\"${1:path/to/module}\" name=\"${2:moduleName}\" attribute=\"${3:attr}\"/>"],
    "description": "Define a custom ISML module"
  },
  "isprint": {
    "prefix": "isprint",
    "body": ["<isprint value=\"${1:value}\" encoding=\"${2|on,off,htmlcontent,htmlsinglequote,htmldoublequote,htmlunquote,jshtml,jsattr,jsblock,jssource,jsonvalue,uricomponent,uristrict,xmlcontent,xmlsinglequote,xmldoublequote,xmlcomment|}\"/>"],
    "description": "Render a value with explicit encoding"
  },
  "isprint-formatter": {
    "prefix": "isprintformatter",
    "body": ["<isprint value=\"${1:value}\" formatter=\"${2:#,##0.00}\"/>"],
    "description": "Render a value with a number/date formatter"
  },
  "isredirect": {
    "prefix": "isredirect",
    "body": ["<isredirect location=\"${1:URLUtils.url('Controller-Action')}\" permanent=\"${2|false,true|}\"/>"],
    "description": "Redirect the response to another URL"
  },
  "iscache": {
    "prefix": "iscache",
    "body": ["<iscache type=\"${1|relative,daily|}\" hour=\"${2:24}\" minute=\"${3:0}\" varyby=\"${4:price_promotion}\"/>"],
    "description": "Configure page caching"
  },
  "isobject": {
    "prefix": "isobject",
    "body": [
      "<isobject object=\"${1:pdict.product}\" view=\"${2:detail}\">",
      "\t$0",
      "</isobject>"
    ],
    "description": "Wrap markup so personalization tracking can pick up the object"
  },
  "isslot": {
    "prefix": "isslot",
    "body": ["<isslot id=\"${1:slot-id}\" description=\"${2:description}\" context=\"${3|global,category,folder|}\" context-object=\"${4:pdict.CurrentCategory}\"/>"],
    "description": "Render a content slot"
  },
  "expression": {
    "prefix": "${",
    "body": ["\\${${1:expression}}"],
    "description": "ISML expression placeholder"
  },
  "resource-msg": {
    "prefix": "resourcemsg",
    "body": ["\\${Resource.msg('${1:key}', '${2:bundle}', null)}"],
    "description": "Localized message via Resource.msg"
  },
  "resource-msgf": {
    "prefix": "resourcemsgf",
    "body": ["\\${Resource.msgf('${1:key}', '${2:bundle}', null, ${3:args})}"],
    "description": "Formatted localized message via Resource.msgf"
  },
  "url": {
    "prefix": "urlutilsurl",
    "body": ["\\${URLUtils.url('${1:Controller-Action}'${2:, 'param', value})}"],
    "description": "Build a URL via URLUtils.url"
  }
}
